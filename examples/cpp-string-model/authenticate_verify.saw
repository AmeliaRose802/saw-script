print "RequestValidator::Authenticate matches the Cryptol spec";
print "under all symbolic inputs satisfying the preconditions.";
*/

// =========================================================================
// Section 11: Summary
// =========================================================================

print "";
print "=== authenticate_verify.saw ===";
print "";
print "This script defines the end-to-end verification of";
print "RequestValidator::Authenticate by composing:";
print "  - String SSO model overrides    (string_overrides.saw)";
print "  - String operation overrides    (string_ops_overrides.saw)";
print "  - Crypto overrides              (crypto_overrides.saw)";
print "  - Chrono/time overrides         (chrono_overrides.saw)";
print "";
print "To run verification:";
print "  1. Compile your C++ source to LLVM bitcode with clang++";
print "  2. Uncomment the llvm_load_module call (Section 4)";
print "  3. Replace all <MANGLED_...> placeholders with actual symbols";
print "     from your bitcode (use llvm-nm to find them)";
print "  4. Uncomment the llvm_verify / llvm_unsafe_assume_spec calls";
print "  5. Run: saw authenticate_verify.saw";
print "";
print "All override specs loaded successfully.";
