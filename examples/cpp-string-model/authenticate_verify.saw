    [ // String model (165.1)
      size_ov, data_ov, cstr_ov, ctor_ov
      // String operations (165.2)
    , cmp_ov, eq_ov, substr_ov, find_ov
      // Crypto (165.3)
    , hmac_ov, sha_ov, b64_ov
      // Chrono/time (165.4)
    , now_ov, from_time_t_ov, lt_ov, gt_ov, count_ov
    ];

// Verify the Authenticate method compositionally.
// SAW will symbolically execute the C++ implementation, intercept every
// call to a string/crypto/time function via the overrides, and check
// that the final return value matches authenticate_spec.
//
// Replace "<MANGLED_Authenticate>" with the actual mangled name of
// RequestValidator::Authenticate from your bitcode.
//   MSVC:    ?Authenticate@RequestValidator@@QEAAHV?$basic_string@DU?$char_traits@D@std@@V?$allocator@D@2@@std@@@Z
//   Itanium: _ZN18RequestValidator12AuthenticateENSt7__cxx1112basic_stringIcSt11char_traitsIcESaIcEEE

