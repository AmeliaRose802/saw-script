// test.saw — Integration test for llvm_bind_method vtable dispatch.
//
// Verifies the full IsMachineEnabled decision rule, not just that the
// indirect call executes: the result must be 1 exactly when the mocked
// keystore call reports SUCCESS and hostDataEnabled is non-zero.

enable_experimental;

m <- llvm_load_module "test.bc";

ks_result <- fresh_symbolic "ks_result" {| [32] |};
host_enabled <- fresh_symbolic "host_enabled" {| [32] |};

let expected_ret = {{
    if (ks_result == (0:[32])) && (host_enabled != (0:[32]))
    then (1:[32])
    else (0:[32])
}};

// Spec for the virtual method: GetMachineConfiguration
// Called through vtable slot 1 (slot 0 = destructor).
let get_config_spec ks_result_val host_enabled_val = do {
    self <- llvm_alloc (llvm_array 16 (llvm_int 8));
    container_id <- llvm_fresh_var "container_id" (llvm_int 32);
    config_out <- llvm_alloc (llvm_int 32);

    llvm_execute_func [self, llvm_term container_id, config_out];

    llvm_points_to config_out (llvm_term host_enabled_val);
    llvm_return (llvm_term ks_result_val);
};

get_config_lemma <- llvm_unsafe_assume_spec m "get_config"
    (get_config_spec ks_result host_enabled);

// Spec for is_machine_enabled with vtable binding.
// The return must exactly match the MSP-style decision:
//   ks_result == SUCCESS && hostDataEnabled != 0
let is_machine_enabled_spec = do {
    keystore <- llvm_alloc_aligned 8 (llvm_array 16 (llvm_int 8));
    container_id <- llvm_fresh_var "container_id" (llvm_int 32);

    llvm_bind_method keystore 1 get_config_lemma;

    llvm_execute_func [keystore, llvm_term container_id];

    llvm_return (llvm_term expected_ret);
};

llvm_verify m "is_machine_enabled" [get_config_lemma] false
    is_machine_enabled_spec
    z3;

print "✓ vtable dispatch test passed";
