// test.saw — Integration test for llvm_bind_method vtable dispatch.
//
// Verifies that is_machine_enabled correctly dispatches through a vtable
// and returns the expected boolean result.

enable_experimental;

m <- llvm_load_module "test.bc";

// Spec for the virtual method: GetMachineConfiguration
// Called through vtable slot 1 (slot 0 = destructor).
let get_config_spec = do {
    self <- llvm_alloc (llvm_array 16 (llvm_int 8));
    container_id <- llvm_fresh_var "container_id" (llvm_int 32);
    config_out <- llvm_alloc (llvm_int 32);

    llvm_execute_func [self, llvm_term container_id, config_out];

    ks_result <- llvm_fresh_var "ks_result" (llvm_int 32);
    host_enabled <- llvm_fresh_var "host_enabled" (llvm_int 32);
    llvm_points_to config_out (llvm_term host_enabled);
    llvm_return (llvm_term ks_result);
};

get_config_lemma <- llvm_unsafe_assume_spec m "get_config" get_config_spec;

// Spec for is_machine_enabled with vtable binding.
// We verify the function executes through the vtable dispatch successfully.
let is_machine_enabled_spec = do {
    keystore <- llvm_alloc (llvm_array 16 (llvm_int 8));
    container_id <- llvm_fresh_var "container_id" (llvm_int 32);

    llvm_bind_method keystore 1 get_config_lemma;

    llvm_execute_func [keystore, llvm_term container_id];

    ret <- llvm_fresh_var "ret" (llvm_int 32);
    llvm_return (llvm_term ret);
};

llvm_verify m "is_machine_enabled" [get_config_lemma] false
    is_machine_enabled_spec
    z3;

print "✓ vtable dispatch test passed";
